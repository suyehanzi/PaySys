# Required for admin login. The app falls back to admin123 in local dev if omitted.
ADMIN_PASSWORD=change-this-password

# Optional but recommended. If omitted, sessions are derived from ADMIN_PASSWORD.
ADMIN_SESSION_SECRET=change-this-random-secret

# Required only for automatic LILISI refresh.
LILISI_EMAIL=your-email@example.com
LILISI_PASSWORD=your-password

# Optional. Defaults to ./data/paysys.sqlite
PAYSYS_DB_PATH=./data/paysys.sqlite
