# Optional encrypted backup settings.
# Keep the real .backup.env and recovery key private.

# Defaults to ../PaySysBackups when omitted.
PAYSYS_BACKUP_REPO_DIR=

# Optional remote Git repository for encrypted backup files.
PAYSYS_BACKUP_REMOTE=

# Prefer using RECOVERY_KEY_DO_NOT_COMMIT.txt in the backup repo or a private env var.
PAYSYS_BACKUP_PASSPHRASE=

# Optional retention period.
PAYSYS_BACKUP_RETENTION_DAYS=30
